import React, { useEffect, useRef, useState } from 'react';
import * as d3 from 'd3';
import * as topojson from 'topojson-client';
import { OCEANS, OceanData, POLLUTION_EVENTS, PollutionEvent, OceanGame as GameType } from '../types';
import { motion, AnimatePresence } from 'motion/react';
import { ZoomIn, MapPin, AlertTriangle, Info, X, Trophy, Gamepad2 } from 'lucide-react';
import { OceanGame } from './OceanGame';

interface GlobeProps {
  onSelectOcean: (ocean: OceanData) => void;
}

const Globe: React.FC<GlobeProps> = ({ onSelectOcean }) => {
  const svgRef = useRef<SVGSVGElement>(null);
  const [rotation, setRotation] = useState<[number, number, number]>([0, -20, 0]);
  const [hoveredOcean, setHoveredOcean] = useState<OceanData | null>(null);
  const [hoveredEvent, setHoveredEvent] = useState<PollutionEvent | null>(null);
  const [hoveredGame, setHoveredGame] = useState<GameType | null>(null);
  const [showPollution, setShowPollution] = useState(false);
  const [showGames, setShowGames] = useState(false);
  const [selectedEvent, setSelectedEvent] = useState<PollutionEvent | null>(null);
  const [selectedGame, setSelectedGame] = useState<GameType | null>(null);

  useEffect(() => {
    if (!svgRef.current) return;

    const width = window.innerWidth;
    const height = window.innerHeight;
    const sensitivity = 150;

    const projection = d3.geoMercator()
      .scale(width / 6.5)
      .translate([width / 2, height / 1.5]);

    const path = d3.geoPath().projection(projection);

    const svg = d3.select(svgRef.current)
      .attr('width', width)
      .attr('height', height);

    svg.selectAll('*').remove();

    // Background (the water)
    const water = svg.append('rect')
      .attr('width', width)
      .attr('height', height)
      .attr('fill', showPollution ? '#1a0f0f' : '#0a192f')
      .style('transition', 'fill 0.5s ease');

    // Graticule (grid lines)
    const graticule = d3.geoGraticule();
    svg.append('path')
      .datum(graticule())
      .attr('class', 'graticule')
      .attr('d', path)
      .attr('fill', 'none')
      .attr('stroke', showPollution ? '#7f1d1d' : '#334155')
      .attr('stroke-width', '0.5px')
      .attr('opacity', 0.3);

    // Draw land
    d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json').then((data: any) => {
      const countries = topojson.feature(data, data.objects.countries) as any;
      
      svg.append('path')
        .datum(countries)
        .attr('d', path)
        .attr('fill', showPollution ? '#262626' : '#1e293b')
        .attr('stroke', showPollution ? '#404040' : '#334155')
        .attr('stroke-width', '0.5px')
        .attr('opacity', 0.8)
        .style('transition', 'fill 0.5s ease');

      // Pollution Hotspots (Glows)
      if (showPollution) {
        const hotspots = svg.selectAll('.hotspot')
          .data(POLLUTION_EVENTS)
          .enter()
          .append('circle')
          .attr('class', 'hotspot')
          .attr('cx', d => projection(d.coordinates)![0])
          .attr('cy', d => projection(d.coordinates)![1])
          .attr('r', d => 40 * d.intensity)
          .attr('fill', 'url(#pollutionGradient)')
          .attr('opacity', 0.6);

        // Add gradient for hotspots
        const defs = svg.append('defs');
        const gradient = defs.append('radialGradient')
          .attr('id', 'pollutionGradient');
        gradient.append('stop').attr('offset', '0%').attr('stop-color', '#ff4d4d').attr('stop-opacity', 0.8);
        gradient.append('stop').attr('offset', '100%').attr('stop-color', '#ff4d4d').attr('stop-opacity', 0);
      }

      // Draw ocean markers
      const markers = svg.selectAll('.ocean-marker')
        .data(OCEANS)
        .enter()
        .append('g')
        .attr('class', 'ocean-marker')
        .style('cursor', 'pointer')
        .on('click', (event, d) => onSelectOcean(d))
        .on('mouseenter', (event, d) => setHoveredOcean(d))
        .on('mouseleave', () => setHoveredOcean(null));

      markers.append('circle')
        .attr('cx', d => projection(d.coordinates)![0])
        .attr('cy', d => projection(d.coordinates)![1])
        .attr('r', 8)
        .attr('fill', d => showPollution ? d3.interpolateReds(d.pollutionIntensity) : d.color)
        .attr('stroke', '#fff')
        .attr('stroke-width', 2)
        .attr('opacity', 1);

      markers.append('text')
        .attr('x', d => projection(d.coordinates)![0] + 12)
        .attr('y', d => projection(d.coordinates)![1] + 5)
        .text(d => d.name)
        .attr('fill', '#fff')
        .attr('font-size', '14px')
        .attr('font-weight', '600')
        .attr('opacity', 1);

      // Pollution Event Markers
      if (showPollution) {
        const eventMarkers = svg.selectAll('.event-marker')
          .data(POLLUTION_EVENTS)
          .enter()
          .append('g')
          .attr('class', 'event-marker')
          .style('cursor', 'pointer')
          .on('click', (event, d) => setSelectedEvent(d))
          .on('mouseenter', (event, d) => setHoveredEvent(d))
          .on('mouseleave', () => setHoveredEvent(null));

        eventMarkers.append('circle')
          .attr('cx', d => projection(d.coordinates)![0])
          .attr('cy', d => projection(d.coordinates)![1])
          .attr('r', 12)
          .attr('fill', d => {
            switch(d.type) {
              case 'Oil Spill': return '#ef4444';
              case 'Garbage Patch': return '#f59e0b';
              case 'Mercury Hotspot': return '#8b5cf6';
              case 'Harmful Algal Bloom': return '#10b981';
              case 'Persistent Organic Pollutants': return '#ec4899';
              default: return '#ef4444';
            }
          })
          .attr('stroke', '#fff')
          .attr('stroke-width', 2)
          .attr('opacity', 1);

        eventMarkers.append('path')
          .attr('d', d => {
            const [x, y] = projection(d.coordinates)!;
            return `M ${x-4} ${y+4} L ${x+4} ${y+4} L ${x} ${y-4} Z`;
          })
          .attr('fill', '#fff')
          .attr('opacity', 1);
      }

        // Game Markers
        if (showGames) {
          const gameMarkers = svg.selectAll('.game-marker')
            .data(OCEANS)
            .enter()
            .append('g')
            .attr('class', 'game-marker')
            .style('cursor', 'pointer')
            .on('click', (event, d) => setSelectedGame(d.game))
            .on('mouseenter', (event, d) => setHoveredGame(d.game))
            .on('mouseleave', () => setHoveredGame(null));

          gameMarkers.append('circle')
            .attr('cx', d => projection(d.coordinates)![0])
            .attr('cy', d => projection(d.coordinates)![1])
            .attr('r', 14)
            .attr('fill', '#3b82f6')
            .attr('stroke', '#fff')
            .attr('stroke-width', 2)
            .attr('opacity', 1);

          gameMarkers.append('path')
            .attr('d', d => {
              const [x, y] = projection(d.coordinates)!;
              return `M ${x-5} ${y+5} L ${x+5} ${y+5} L ${x} ${y-5} Z`;
            })
            .attr('fill', '#fff')
            .attr('opacity', 1);
        }
      });

    // Drag behavior (Panning)
    const drag = d3.drag<SVGSVGElement, unknown>()
      .on('drag', (event) => {
        const currTranslate = projection.translate();
        projection.translate([
          currTranslate[0] + event.dx,
          currTranslate[1] + event.dy
        ]);
        setRotation([0, 0, 0]); // Dummy update to trigger re-render
      });

    svg.call(drag);

    return () => {};
  }, [rotation, hoveredOcean, hoveredEvent, hoveredGame, onSelectOcean, showPollution, showGames, selectedEvent, selectedGame]);

  return (
    <div className="relative w-full h-screen bg-slate-950 overflow-hidden flex items-center justify-center">
      {/* Sidebar UI */}
      <div className="absolute top-10 right-10 z-10 text-white flex flex-col gap-6 items-end text-right">
        <div>
          <h1 className="text-5xl font-bold tracking-tighter mb-2 italic serif">OCEAN EXPLORER</h1>
          <p className="text-slate-400 max-w-md">
            Drag to pan the map. Click on an ocean marker to dive into its depths.
          </p>
        </div>

        {/* Toggles */}
        <div className="flex flex-col gap-4 items-end">
          {/* Pollution Toggle */}
          <div className="bg-white/5 backdrop-blur-md border border-white/10 p-5 rounded-3xl max-w-xs transition-all hover:bg-white/10">
            <div className="flex items-center justify-between gap-8 mb-2">
              <div className="flex items-center gap-2">
                <AlertTriangle className={`w-4 h-4 ${showPollution ? 'text-red-500' : 'text-slate-400'}`} />
                <span className="font-bold uppercase tracking-widest text-[10px]">Pollution Map</span>
              </div>
              <label className="relative inline-flex items-center cursor-pointer scale-75">
                <input 
                  type="checkbox" 
                  className="sr-only peer" 
                  checked={showPollution}
                  onChange={() => setShowPollution(!showPollution)}
                />
                <div className="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-red-600"></div>
              </label>
            </div>
            <p className="text-[9px] text-slate-400 leading-tight">
              Visualize garbage patches and pollution hotspots.
            </p>
          </div>

          {/* Games Toggle */}
          <div className="bg-white/5 backdrop-blur-md border border-white/10 p-5 rounded-3xl max-w-xs transition-all hover:bg-white/10">
            <div className="flex items-center justify-between gap-8 mb-2">
              <div className="flex items-center gap-2">
                <Gamepad2 className={`w-4 h-4 ${showGames ? 'text-blue-400' : 'text-slate-400'}`} />
                <span className="font-bold uppercase tracking-widest text-[10px]">Ocean Games</span>
              </div>
              <label className="relative inline-flex items-center cursor-pointer scale-75">
                <input 
                  type="checkbox" 
                  className="sr-only peer" 
                  checked={showGames}
                  onChange={() => setShowGames(!showGames)}
                />
                <div className="w-11 h-6 bg-slate-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
              </label>
            </div>
            <p className="text-[9px] text-slate-400 leading-tight">
              Play mini-games to learn about marine life and conservation.
            </p>
          </div>
        </div>
      </div>

      <svg ref={svgRef} className="cursor-grab active:cursor-grabbing" />

      {/* Hover Info Tooltip */}
      <AnimatePresence>
        {(hoveredOcean || hoveredEvent || hoveredGame) && !selectedEvent && !selectedGame && (
          <motion.div
            initial={{ opacity: 0, y: 20, scale: 0.95 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            exit={{ opacity: 0, y: 20, scale: 0.95 }}
            className="absolute bottom-10 left-1/2 -translate-x-1/2 bg-slate-900/80 backdrop-blur-xl border border-white/20 p-5 rounded-3xl text-white flex items-center gap-5 pointer-events-none shadow-2xl min-w-[300px]"
          >
            <div className="w-14 h-14 rounded-2xl flex items-center justify-center shadow-inner" 
                 style={{ 
                   backgroundColor: hoveredOcean 
                     ? (showPollution ? d3.interpolateReds(hoveredOcean.pollutionIntensity) : hoveredOcean.color)
                     : hoveredEvent ? '#ef4444' : '#3b82f6'
                 }}>
              {hoveredOcean && <MapPin className="w-7 h-7" />}
              {hoveredEvent && <AlertTriangle className="w-7 h-7" />}
              {hoveredGame && <Trophy className="w-7 h-7" />}
            </div>
            <div>
              <h3 className="text-2xl font-black tracking-tight leading-none mb-1 uppercase italic serif">
                {hoveredOcean?.name || hoveredEvent?.name || hoveredGame?.name}
