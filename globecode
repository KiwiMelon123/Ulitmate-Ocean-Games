import React, { useState, useEffect, useRef } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { X, Trophy, Info, Play } from 'lucide-react';
import { OceanGame as GameType } from '../types';

interface OceanGameProps {
  game: GameType;
  onClose: () => void;
}

export const OceanGame: React.FC<OceanGameProps> = ({ game, onClose }) => {
  const [gameState, setGameState] = useState<'start' | 'playing' | 'finished'>('start');
  const [score, setScore] = useState(0);
  const [timeLeft, setTimeLeft] = useState(15);
  const [gameItems, setGameItems] = useState<{ id: number; x: number; y: number; type: string }[]>([]);
  const gameContainerRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (gameState === 'playing') {
      const timer = setInterval(() => {
        setTimeLeft((prev) => {
          if (prev <= 1) {
            setGameState('finished');
            return 0;
          }
          return prev - 1;
        });
      }, 1000);

      const itemSpawner = setInterval(() => {
        setGameItems((prev) => [
          ...prev,
          {
            id: Math.random(),
            x: Math.random() * 80 + 10,
            y: Math.random() * 80 + 10,
            type: game.type === 'cleanup' ? 'plastic' : game.type === 'feeding' ? 'food' : 'target'
          }
        ].slice(-10));
      }, 800);

      return () => {
        clearInterval(timer);
        clearInterval(itemSpawner);
      };
    }
  }, [gameState, game.type]);

  const handleItemClick = (id: number) => {
    setGameItems((prev) => prev.filter(item => item.id !== id));
    setScore((prev) => prev + 1);
  };

  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      className="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4"
    >
      <motion.div
        initial={{ scale: 0.9, y: 20 }}
        animate={{ scale: 1, y: 0 }}
        className="bg-slate-900 border border-slate-700 rounded-3xl w-full max-w-2xl overflow-hidden shadow-2xl flex flex-col"
        style={{ height: '500px' }}
      >
        {/* Header */}
        <div className="p-6 border-b border-slate-800 flex justify-between items-center bg-slate-900/50">
          <div>
            <h2 className="text-2xl font-bold text-white flex items-center gap-2">
              <Trophy className="text-yellow-500 w-6 h-6" />
              {game.name}
            </h2>
            <p className="text-slate-400 text-sm">{game.description}</p>
          </div>
          <button
            onClick={onClose}
            className="p-2 hover:bg-slate-800 rounded-full transition-colors text-slate-400 hover:text-white"
          >
            <X size={24} />
          </button>
        </div>

        {/* Game Area */}
        <div className="flex-1 relative overflow-hidden bg-slate-950" ref={gameContainerRef}>
          <AnimatePresence mode="wait">
            {gameState === 'start' && (
              <motion.div
                key="start"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="absolute inset-0 flex flex-col items-center justify-center p-8 text-center"
              >
                <div className="bg-blue-500/10 p-4 rounded-full mb-6">
                  <Play className="text-blue-400 w-12 h-12 fill-blue-400" />
                </div>
                <h3 className="text-xl font-semibold text-white mb-4">How to Play</h3>
                <p className="text-slate-300 mb-8 max-w-md">
                  {game.instructions}
                </p>
                <button
                  onClick={() => setGameState('playing')}
                  className="px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-full font-bold transition-all transform hover:scale-105"
                >
                  Start Game
                </button>
              </motion.div>
            )}

            {gameState === 'playing' && (
              <motion.div
                key="playing"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="absolute inset-0"
              >
                {/* HUD */}
                <div className="absolute top-4 left-4 right-4 flex justify-between items-center z-10">
                  <div className="bg-slate-900/80 backdrop-blur px-4 py-2 rounded-full border border-slate-700">
                    <span className="text-slate-400 text-xs uppercase tracking-widest mr-2">Score</span>
                    <span className="text-white font-mono font-bold text-lg">{score}</span>
                  </div>
                  <div className="bg-slate-900/80 backdrop-blur px-4 py-2 rounded-full border border-slate-700">
                    <span className="text-slate-400 text-xs uppercase tracking-widest mr-2">Time</span>
                    <span className={`font-mono font-bold text-lg ${timeLeft < 5 ? 'text-red-500 animate-pulse' : 'text-white'}`}>
                      {timeLeft}s
                    </span>
                  </div>
                </div>

                {/* Game Items */}
                {gameItems.map((item) => (
                  <motion.button
                    key={item.id}
                    initial={{ scale: 0, opacity: 0 }}
                    animate={{ scale: 1, opacity: 1 }}
                    exit={{ scale: 0, opacity: 0 }}
                    whileHover={{ scale: 1.1 }}
                    whileTap={{ scale: 0.9 }}
                    onClick={() => handleItemClick(item.id)}
                    className="absolute p-3 rounded-full cursor-pointer z-20"
                    style={{ left: `${item.x}%`, top: `${item.y}%` }}
                  >
                    <div className={`w-10 h-10 rounded-full flex items-center justify-center shadow-lg ${
                      game.type === 'cleanup' ? 'bg-red-500/20 border border-red-500/50' :
                      game.type === 'feeding' ? 'bg-green-500/20 border border-green-500/50' :
                      'bg-blue-500/20 border border-blue-500/50'
                    }`}>
                      {game.type === 'cleanup' ? '🥤' : game.type === 'feeding' ? '🌿' : '🎯'}
                    </div>
                  </motion.button>
                ))}

                {/* Background Decoration */}
                <div className="absolute inset-0 opacity-10 pointer-events-none">
                  <div className="absolute top-1/4 left-1/4 w-32 h-32 bg-blue-500 rounded-full blur-3xl" />
                  <div className="absolute bottom-1/4 right-1/4 w-40 h-40 bg-indigo-500 rounded-full blur-3xl" />
                </div>
              </motion.div>
            )}

            {gameState === 'finished' && (
              <motion.div
                key="finished"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="absolute inset-0 flex flex-col items-center justify-center p-8 text-center bg-slate-950/90"
              >
                <div className="bg-yellow-500/10 p-6 rounded-full mb-6">
                  <Trophy className="text-yellow-500 w-16 h-16" />
                </div>
                <h3 className="text-3xl font-bold text-white mb-2">Game Over!</h3>
                <p className="text-slate-400 mb-6">You scored <span className="text-white font-bold">{score}</span> points</p>
                
                <div className="bg-slate-900 border border-slate-800 p-6 rounded-2xl mb-8 max-w-md text-left">
                  <div className="flex items-center gap-2 text-blue-400 mb-3">
                    <Info size={18} />
                    <span className="text-xs font-bold uppercase tracking-widest">Did you know?</span>
                  </div>
                  <p className="text-slate-300 italic leading-relaxed">
                    "{game.fact}"
                  </p>
                </div>

                <div className="flex gap-4">
                  <button
                    onClick={() => {
                      setGameState('playing');
                      setScore(0);
                      setTimeLeft(15);
                      setGameItems([]);
                    }}
                    className="px-8 py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-full font-bold transition-all"
                  >
                    Play Again
                  </button>
                  <button
                    onClick={onClose}
                    className="px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-full font-bold transition-all"
                  >
                    Back to Globe
                  </button>
                </div>
              </motion.div>
            )}
          </AnimatePresence>
        </div>
      </motion.div>
    </motion.div>
  );
};

