import { useState } from 'react';
import Globe from './components/Globe';
import DepthView from './components/DepthView';
import { OceanData } from './types';
import { motion, AnimatePresence } from 'motion/react';

export default function App() {
  const [selectedOcean, setSelectedOcean] = useState<OceanData | null>(null);

  return (
    <main className="w-full h-screen bg-slate-950">
      <AnimatePresence mode="wait">
        {!selectedOcean ? (
          <motion.div
            key="globe"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0, scale: 1.5, filter: 'blur(10px)' }}
            transition={{ duration: 0.4, ease: "easeInOut" }}
            className="w-full h-full"
          >
            <Globe onSelectOcean={setSelectedOcean} />
          </motion.div>
        ) : (
          <motion.div
            key="depth"
            initial={{ opacity: 0, scale: 0.8 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0 }}
            transition={{ duration: 0.4, ease: "easeOut" }}
            className="w-full h-full overflow-y-auto"
          >
            <DepthView 
              ocean={selectedOcean} 
              onBack={() => setSelectedOcean(null)} 
            />
          </motion.div>
        )}
      </AnimatePresence>
    </main>
  );
}

import React, { useState, useRef } from 'react';
import { motion, useScroll, useTransform, AnimatePresence, useSpring } from 'motion/react';
import { OceanData, Organism } from '../types';
import { ArrowLeft, Waves, ChevronDown, Info } from 'lucide-react';

interface DepthViewProps {
  ocean: OceanData;
  onBack: () => void;
}

const DepthView: React.FC<DepthViewProps> = ({ ocean, onBack }) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const { scrollYProgress } = useScroll({
    target: containerRef,
    offset: ["start start", "end end"]
  });

  const [selectedOrganism, setSelectedOrganism] = useState<Organism | null>(null);

  // Smooth scroll progress for background and depth indicator
  const smoothProgress = useSpring(scrollYProgress, {
    stiffness: 100,
    damping: 30,
    restDelta: 0.001
  });

  // Background color transition from light blue to dark blue/black
  const background = useTransform(
    smoothProgress,
    [0, 0.1, 0.3, 0.6, 1],
    ['#e0f2fe', '#0ea5e9', '#0c4a6e', '#020617', '#000000']
  );

  const textColor = useTransform(
    smoothProgress,
    [0, 0.1],
    ['#0f172a', '#f8fafc']
  );

  // Map 0-1 progress to 0-4000m depth
  const currentDepth = useTransform(smoothProgress, [0, 1], [0, 4000]);

  // Sort organisms by depth
  const sortedOrganisms = [...ocean.organisms].sort((a, b) => a.depth - b.depth);

  return (
    <motion.div 
      ref={containerRef}
      style={{ background }} 
      className="relative min-h-[1000vh] w-full overflow-x-hidden"
    >
      {/* Fixed UI Overlay */}
      <div className="fixed inset-0 pointer-events-none z-40">
        {/* Header */}
        <motion.div 
          style={{ color: textColor }}
          className="absolute top-0 left-0 w-full p-8 flex justify-between items-center pointer-events-auto"
        >
          <button 
            onClick={onBack}
            className="flex items-center gap-2 hover:opacity-70 transition-opacity group bg-black/10 backdrop-blur-md px-4 py-2 rounded-full border border-white/10"
          >
            <ArrowLeft className="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
            <span className="font-bold uppercase tracking-widest text-xs">Globe</span>
          </button>
          <div className="text-right">
            <h2 className="text-2xl font-black italic serif uppercase leading-none">{ocean.name}</h2>
            <motion.p className="text-[10px] uppercase tracking-[0.2em] opacity-70">
              Depth: <motion.span className="font-mono">{useTransform(currentDepth, (v) => Math.round(v))}</motion.span>m
            </motion.p>
          </div>
        </motion.div>

        {/* Depth Gauge */}
        <div className="absolute left-8 top-1/2 -translate-y-1/2 h-64 w-1 bg-white/10 rounded-full overflow-hidden">
          <motion.div 
            style={{ height: useTransform(smoothProgress, [0, 1], ['0%', '100%']) }}
            className="w-full bg-blue-400 shadow-[0_0_15px_rgba(96,165,250,0.8)]"
          />
        </div>
      </div>

      {/* Surface Intro */}
      <div className="h-screen flex flex-col items-center justify-center text-center px-6 relative z-10">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="text-slate-900"
        >
          <Waves className="w-16 h-16 mb-6 mx-auto opacity-40" />
          <h1 className="text-8xl font-black tracking-tighter mb-4 uppercase">The Surface</h1>
          <p className="text-xl max-w-xl mx-auto opacity-70 font-medium">
            Begin your descent into the {ocean.name}. Scroll down to explore the layers of life hidden beneath the waves.
          </p>
          <motion.div 
            animate={{ y: [0, 10, 0] }}
            transition={{ repeat: Infinity, duration: 2 }}
            className="mt-12"
          >
            <ChevronDown className="w-8 h-8 opacity-30 mx-auto" />
          </motion.div>
        </motion.div>
      </div>

      {/* Depth-Mapped Organisms */}
      <div className="relative w-full max-w-6xl mx-auto">
        {sortedOrganisms.map((organism, index) => {
          // Calculate vertical position based on depth (0-4000m mapped to container height)
          // We use a non-linear mapping to give more space to the surface and twilight zones
          const verticalPos = (Math.sqrt(organism.depth) / Math.sqrt(4000)) * 100;
          
          return (
            <motion.div
              key={organism.id}
              initial={{ opacity: 0, scale: 0.5, y: 50 }}
              whileInView={{ opacity: 1, scale: 1, y: 0 }}
              viewport={{ margin: "-50px" }}
              transition={{ 
                duration: 1.2, 
                ease: [0.22, 1, 0.36, 1] 
              }}
              style={{ 
                top: `${verticalPos + 10}vh`,
                left: `${(index % 2 === 0 ? 10 : 60) + (Math.random() * 15)}%`
              }}
              className="absolute z-20 group cursor-pointer"
              onClick={() => setSelectedOrganism(organism)}
            >
              {/* Swimming/Floating Animation */}
              <motion.div
                animate={{ 
                  x: [0, 20, -20, 0],
                  y: [0, -15, 15, 0],
                  rotate: [0, 3, -3, 0]
                }}
                transition={{ 
                  duration: 6 + Math.random() * 4, 
                  repeat: Infinity, 
                  ease: "easeInOut" 
                }}
                className="relative flex flex-col items-center"
              >
                {/* Specimen Frame */}
                <div className="relative">
                  {/* Glow effect */}
                  <div className="absolute -inset-8 bg-blue-500/10 rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
                  
                  {/* Image Circle */}
                  <div className="relative w-40 h-40 md:w-56 md:h-56 rounded-full border-2 border-white/20 overflow-hidden shadow-[0_0_30px_rgba(0,0,0,0.5)] group-hover:border-blue-400/50 transition-colors duration-500">
                    <img 
                      src={organism.imageUrl} 
                      alt={organism.name}
                      className="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                      referrerPolicy="no-referrer"
                    />
                    {/* Water Overlay */}
                    <div className="absolute inset-0 bg-blue-900/20 mix-blend-overlay" />
                  </div>

                  {/* Depth Label Tag */}
                  <div className="absolute -top-4 -right-4 bg-white/10 backdrop-blur-md border border-white/20 px-3 py-1 rounded-full">
                    <span className="text-[10px] font-mono text-white/80">{organism.depth}m</span>
                  </div>
                </div>

                {/* Name Label (appears on hover or nearby) */}
                <motion.div 
                  className="mt-4 text-center"
                  initial={{ opacity: 0.4 }}
                  whileHover={{ opacity: 1 }}
                >
                  <h3 className="text-lg font-black text-white uppercase tracking-tighter group-hover:text-blue-300 transition-colors">{organism.name}</h3>
                  <div className="h-px w-0 group-hover:w-full bg-blue-400/50 mx-auto transition-all duration-500" />
                </motion.div>
              </motion.div>
            </motion.div>
          );
        })}
      </div>

      {/* Bottom Abyss */}
      <div className="h-screen flex flex-col items-center justify-center text-center px-6 relative z-10 mt-[900vh]">
        <motion.div
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          className="text-white/20"
        >
          <h2 className="text-9xl font-black tracking-tighter uppercase">The Abyss</h2>
          <p className="text-lg max-w-md mx-auto font-mono tracking-widest uppercase mt-4">
            End of exploration • 4000m+
          </p>
        </motion.div>
      </div>

      {/* Modal */}
      <AnimatePresence>
        {selectedOrganism && (
